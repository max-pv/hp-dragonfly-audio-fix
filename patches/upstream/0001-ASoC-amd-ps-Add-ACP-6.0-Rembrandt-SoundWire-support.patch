From 2371b82130ddd9f31b8b10c4f181febb33be562e Mon Sep 17 00:00:00 2001
From: Max Pimenov <max.a.pimenov@gmail.com>
Date: Sun, 1 Mar 2026 15:33:03 -0800
Subject: [PATCH 1/6] ASoC: amd: Add ACP 6.0 Rembrandt SoundWire support

Signed-off-by: Max Pimenov <max.a.pimenov@gmail.com>

diff --git a/sound/soc/amd/ps/acp63.h b/sound/soc/amd/ps/acp63.h
index 90fc016..677f803 100644
--- a/sound/soc/amd/ps/acp63.h
+++ b/sound/soc/amd/ps/acp63.h
@@ -61,6 +61,9 @@
 
 #define ACP63_DMIC_ADDR			2
 #define ACP63_SDW_ADDR			5
+#define ACP60_PCI_REV			0x60
+#define ACP6F_PCI_REV			0x6f
+#define ACP60_SDW_ADDR			2
 #define AMD_SDW_MAX_MANAGERS		2
 
 /* time in ms for acp timeout */
@@ -370,6 +374,8 @@ struct acp63_dev_data {
 	u32 addr;
 	u32 reg_range;
 	u32 acp_rev;
+	u32 subsystem_vendor;
+	u32 subsystem_device;
 	u32 acp_sw_pad_keeper_en;
 	u32 acp_pad_pulldown_ctrl;
 	u16 acp63_sdw0_dma_intr_stat[ACP63_SDW0_DMA_MAX_STREAMS];
diff --git a/sound/soc/amd/ps/pci-ps.c b/sound/soc/amd/ps/pci-ps.c
index c62299b..ea0e6e0 100644
--- a/sound/soc/amd/ps/pci-ps.c
+++ b/sound/soc/amd/ps/pci-ps.c
@@ -112,6 +112,8 @@ static short int check_and_handle_sdw_dma_irq(struct acp63_dev_data *adata, u32
 					break;
 				}
 				switch (adata->acp_rev) {
+				case ACP60_PCI_REV:
+				case ACP6F_PCI_REV:
 				case ACP63_PCI_REV:
 					adata->acp63_sdw0_dma_intr_stat[stream_id] = 1;
 					break;
@@ -126,6 +128,8 @@ static short int check_and_handle_sdw_dma_irq(struct acp63_dev_data *adata, u32
 		}
 	}
 	switch (adata->acp_rev) {
+	case ACP60_PCI_REV:
+	case ACP6F_PCI_REV:
 	case ACP63_PCI_REV:
 		if (ext_intr_stat1 & ACP63_P1_AUDIO1_RX_THRESHOLD) {
 			writel(ACP63_P1_AUDIO1_RX_THRESHOLD,
@@ -335,6 +339,12 @@ static struct snd_soc_acpi_mach *acp63_sdw_machine_select(struct device *dev)
 			mach->mach_params.links = mach->links;
 			mach->mach_params.link_mask = mach->link_mask;
 			mach->mach_params.subsystem_rev = acp_data->acp_rev;
+			mach->mach_params.subsystem_vendor = acp_data->subsystem_vendor;
+			mach->mach_params.subsystem_device = acp_data->subsystem_device;
+			mach->mach_params.subsystem_id_set = true;
+
+			dev_dbg(dev, "SSID %x%x\n", mach->mach_params.subsystem_vendor,
+				mach->mach_params.subsystem_device);
 			return mach;
 		}
 	}
@@ -430,8 +440,21 @@ static int get_acp63_device_config(struct pci_dev *pci, struct acp63_dev_data *a
 	if (dmic_en && wov_en)
 		is_dmic_dev = true;
 
+	/*
+	 * HP Dragonfly Pro (ACP6.0) firmware exposes SoundWire ACPI children but
+	 * does not mark the internal DMIC node with acp-audio-device-type.
+	 * Force-enable PDM so the machine driver can register DMIC capture.
+	 */
+	if (!is_dmic_dev &&
+	    acp_data->acp_rev == 0x60 &&
+	    acp_data->subsystem_vendor == 0x103c &&
+	    acp_data->subsystem_device == 0x8a7f)
+		is_dmic_dev = true;
+
 	if (acp_data->is_sdw_config) {
-		ret = acp_scan_sdw_devices(&pci->dev, ACP63_SDW_ADDR);
+		u64 sdw_addr = (acp_data->acp_rev < ACP63_PCI_REV) ?
+				ACP60_SDW_ADDR : ACP63_SDW_ADDR;
+		ret = acp_scan_sdw_devices(&pci->dev, sdw_addr);
 		if (!ret && acp_data->info.link_mask)
 			is_sdw_dev = true;
 	}
@@ -549,6 +572,8 @@ static int acp_hw_init_ops(struct acp63_dev_data *adata, struct pci_dev *pci)
 		return -ENOMEM;
 
 	switch (adata->acp_rev) {
+	case ACP60_PCI_REV:
+	case ACP6F_PCI_REV:
 	case ACP63_PCI_REV:
 		acp63_hw_init_ops(adata->hw_ops);
 		break;
@@ -581,6 +606,8 @@ static int snd_acp63_probe(struct pci_dev *pci,
 
 	/* ACP PCI revision id check for ACP6.3, ACP7.0 & ACP7.1 platforms */
 	switch (pci->revision) {
+	case ACP60_PCI_REV:
+	case ACP6F_PCI_REV:
 	case ACP63_PCI_REV:
 	case ACP70_PCI_REV:
 	case ACP71_PCI_REV:
@@ -617,6 +644,9 @@ static int snd_acp63_probe(struct pci_dev *pci,
 	adata->addr = addr;
 	adata->reg_range = ACP63_REG_END - ACP63_REG_START;
 	adata->acp_rev = pci->revision;
+	adata->subsystem_vendor = pci->subsystem_vendor;
+	adata->subsystem_device = pci->subsystem_device;
+
 	pci_set_master(pci);
 	pci_set_drvdata(pci, adata);
 	mutex_init(&adata->acp_lock);
diff --git a/sound/soc/amd/ps/ps-sdw-dma.c b/sound/soc/amd/ps/ps-sdw-dma.c
index 5449323..62b1827 100644
--- a/sound/soc/amd/ps/ps-sdw-dma.c
+++ b/sound/soc/amd/ps/ps-sdw-dma.c
@@ -247,6 +247,8 @@ static int acp63_configure_sdw_ringbuffer(void __iomem *acp_base, u32 stream_id,
 	u32 sdw_mem_window_offset;
 
 	switch (acp_rev) {
+	case ACP60_PCI_REV:
+	case ACP6F_PCI_REV:
 	case ACP63_PCI_REV:
 		switch (manager_instance) {
 		case ACP_SDW0:
@@ -360,6 +362,8 @@ static int acp63_sdw_dma_hw_params(struct snd_soc_component *component,
 		return -EINVAL;
 	stream_id = stream->stream_id;
 	switch (sdw_data->acp_rev) {
+	case ACP60_PCI_REV:
+	case ACP6F_PCI_REV:
 	case ACP63_PCI_REV:
 		switch (stream->instance) {
 		case ACP_SDW0:
@@ -437,6 +441,8 @@ static u64 acp63_sdw_get_byte_count(struct acp_sdw_dma_stream *stream, void __io
 
 	byte_count.bytescount = 0;
 	switch (acp_rev) {
+	case ACP60_PCI_REV:
+	case ACP6F_PCI_REV:
 	case ACP63_PCI_REV:
 		switch (stream->instance) {
 		case ACP_SDW0:
@@ -518,6 +524,8 @@ static int acp63_sdw_dma_close(struct snd_soc_component *component,
 	if (!stream)
 		return -EINVAL;
 	switch (sdw_data->acp_rev) {
+	case ACP60_PCI_REV:
+	case ACP6F_PCI_REV:
 	case ACP63_PCI_REV:
 		switch (stream->instance) {
 		case ACP_SDW0:
@@ -564,6 +572,8 @@ static int acp63_sdw_dma_enable(struct snd_pcm_substream *substream,
 	stream = substream->runtime->private_data;
 	stream_id = stream->stream_id;
 	switch (acp_rev) {
+	case ACP60_PCI_REV:
+	case ACP6F_PCI_REV:
 	case ACP63_PCI_REV:
 		switch (stream->instance) {
 		case ACP_SDW0:
@@ -777,7 +787,7 @@ static int acp63_sdw_pcm_resume(struct device *dev)
 	struct sdw_dma_dev_data *sdw_data;
 
 	sdw_data = dev_get_drvdata(dev);
-	if (sdw_data->acp_rev == ACP63_PCI_REV)
+	if (sdw_data->acp_rev <= ACP63_PCI_REV)
 		return acp63_restore_sdw_dma_config(sdw_data);
 	else
 		return acp70_restore_sdw_dma_config(sdw_data);
diff --git a/sound/soc/amd/yc/pci-acp6x.c b/sound/soc/amd/yc/pci-acp6x.c
index 1140ed1..bd2247e 100644
--- a/sound/soc/amd/yc/pci-acp6x.c
+++ b/sound/soc/amd/yc/pci-acp6x.c
@@ -6,6 +6,7 @@
  */
 
 #include <linux/pci.h>
+#include <linux/acpi.h>
 #include <linux/module.h>
 #include <linux/io.h>
 #include <linux/delay.h>
@@ -161,13 +162,20 @@ static int snd_acp6x_probe(struct pci_dev *pci,
 
 	/* Yellow Carp device check */
 	switch (pci->revision) {
-	case 0x60:
-	case 0x6f:
+	case ACP60_PCI_REV:
+	case ACP6F_PCI_REV:
 		break;
 	default:
 		dev_dbg(&pci->dev, "acp6x pci device not found\n");
 		return -ENODEV;
 	}
+
+	/* Defer to pci-ps driver if SoundWire controller is described in ACPI */
+	if (ACPI_COMPANION(&pci->dev) &&
+	    acpi_find_child_device(ACPI_COMPANION(&pci->dev), 2, 0)) {
+		dev_dbg(&pci->dev, "SoundWire ACPI device found, deferring\n");
+		return -ENODEV;
+	}
 	if (pci_enable_device(pci)) {
 		dev_err(&pci->dev, "pci_enable_device failed\n");
 		return -ENODEV;
